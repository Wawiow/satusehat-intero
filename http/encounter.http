@baseUrl = http://localhost:8080/api
@token = 7YnJUgC57bMiqdtv7Rxym1cAHSpT

### Get All Local Patients
GET {{baseUrl}}/local/patients
Content-Type: application/json

### Get All Local Locations
GET {{baseUrl}}/local/locations
Content-Type: application/json

### Create Encounter - Dinamis (Ganti ID sesuai patient & location yang ada)
# Status: arrived (pasien baru tiba)
# Kelas: AMB (ambulatory)
# Timestamp: ISO 8601 UTC+0 (waktu request saat ini)
# 
# PETUNJUK:
# 1. Jalankan "Get All Local Patients" untuk lihat daftar patient
# 2. Jalankan "Get All Local Locations" untuk lihat daftar location
# 3. Ganti subject_id dan location_id di bawah dengan ID yang ada
# 4. identifier_value bisa disesuaikan (gunakan format yang konsisten)
# 5. practitioner_id bisa disesuaikan dengan ID practitioner yang ada

POST {{baseUrl}}/encounters
Content-Type: application/json

{
  "identifier_value": "ENC-{{$timestamp}}-001",
  "subject_id": "Patient/12300000000010",
  "location_id": "Location/556e4d8d-6e73-45a2-8283-b73374634c43",
  "practitioner_id": "Practitioner/N10008465328",
  "start_time": "2026-06-05T10:30:00Z"
}

### Create Encounter - Contoh 1 (Patient/Location dari DB)
POST {{baseUrl}}/encounters
Content-Type: application/json

{
  "identifier_value": "ENC-KUNJUNGAN-001",
  "subject_id": "Patient/12300000000010",
  "location_id": "Location/556e4d8d-6e73-45a2-8283-b73374634c43",
  "practitioner_id": "Practitioner/N10008465328",
  "start_time": "2026-06-05T15:45:00Z"
}

### Create Encounter - Contoh 2 (Ganti dengan ID lain)
POST {{baseUrl}}/encounters
Content-Type: application/json

{
  "identifier_value": "ENC-KUNJUNGAN-002",
  "subject_id": "Patient/12300000000010",
  "location_id": "Location/556e4d8d-6e73-45a2-8283-b73374634c43",
  "practitioner_id": "Practitioner/N10008465328",
  "start_time": "2026-06-05T09:15:00Z"
}

### Get Encounter by ID
GET {{baseUrl}}/encounters/de122fc5-3aa8-4d37-84a5-244e969c8164
Content-Type: application/json

### Get All Local Encounters
GET {{baseUrl}}/local/encounters
Content-Type: application/json

### Update Encounter Status (InProgress)
PUT {{baseUrl}}/encounters/de122fc5-3aa8-4d37-84a5-244e969c8164
Content-Type: application/json

{
  "status": "in-progress"
}

### Update Encounter Status (Finished)
PUT {{baseUrl}}/encounters/de122fc5-3aa8-4d37-84a5-244e969c8164
Content-Type: application/json

{
  "status": "finished"
}
