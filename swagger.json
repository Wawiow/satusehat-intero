                "summary": "Get Patient",
                "parameters": [
                    {
                        "type": "string",
                        "description": "NIK of the patient",
                        "name": "nik",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Name of the patient (required if searching SatuSehat)",
                        "name": "name",
                        "in": "query"
                    }
