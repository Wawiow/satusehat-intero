                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/api.LocationResponse"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
