            "post": {
                "description": "Get a fresh OAuth2 bearer token from SatuSehat",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "Get SatuSehat OAuth Token",
                "responses": {
                    "200": {
                        "description": "OK",
